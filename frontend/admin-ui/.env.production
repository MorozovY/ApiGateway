# Production environment variables for admin-ui
# Used by Vite during CI build (npm run build)

# Grafana URL (centralized infra - Story 13.11)
VITE_GRAFANA_URL=https://grafana.ymorozov.ru

# Keycloak Integration (Story 12.2)
VITE_KEYCLOAK_URL=https://keycloak.ymorozov.ru
VITE_KEYCLOAK_REALM=api-gateway
VITE_KEYCLOAK_CLIENT_ID=gateway-admin-ui
