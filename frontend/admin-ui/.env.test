# Test Environment (для unit тестов vitest)
# Переопределяет .env когда запущен через npm run test

# Keycloak Server URL (для тестов)
VITE_KEYCLOAK_URL=http://localhost:8180

# Keycloak Realm name
VITE_KEYCLOAK_REALM=api-gateway

# Keycloak Client ID
VITE_KEYCLOAK_CLIENT_ID=gateway-admin-ui

# Grafana URL
VITE_GRAFANA_URL=http://localhost:3001
