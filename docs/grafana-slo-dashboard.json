        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum(increase(gateway_requests_total{status!~\"5..\"}[30d])) / sum(increase(gateway_requests_total[30d])) * 100",
          "legendFormat": "Availability",
          "refId": "A"
        }
      ],
      "title": "SLO Compliance (30d)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "max": 100,
