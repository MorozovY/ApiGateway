      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "(1 - (1 - sum(increase(gateway_requests_total{status!~\"5..\"}[30d])) / sum(increase(gateway_requests_total[30d]))) / 0.001) * 100",
